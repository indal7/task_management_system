# Terraform State files – never commit
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Variable files that contain real secrets
terraform.tfvars
*.auto.tfvars
environments/*/secrets.tfvars
# Allow environment-specific template tfvars (contain only placeholders, no real secrets)
!environments/dev/terraform.tfvars
!environments/prod/terraform.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc
