# Development Dockerfile – uses dev requirements and Flask built-in server
FROM python:3.11-slim

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    FLASK_ENV=development

# Set working directory
WORKDIR /app


# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev gcc python3-dev curl \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for layer caching
COPY requirements/base.txt requirements/base.txt
COPY requirements/dev.txt requirements/dev.txt

# Install dev + base Python dependencies
RUN pip install --no-cache-dir -r requirements/base.txt -r requirements/dev.txt

# Copy the application code (overridden by volume mount in compose)
COPY . /app

# Expose port
EXPOSE 5000

# Run Flask development server
CMD ["python", "app.py"]
